# Скопируй в .env и заполни. Файл .env НЕ коммитить — в нём секреты.

# Домен инстанса. На него Caddy получит сертификат Let's Encrypt,
# поэтому A-запись должна вести на публичный IP этого сервера.
COVE_DOMAIN=mistyworks.servebeer.com

# Пароль Postgres. Сгенерировать: openssl rand -base64 24
COVE_DB_PASSWORD=

# Ключи LiveKit. Секрет ОБЯЗАН быть не короче 32 символов.
#   COVE_LIVEKIT_API_KEY:    openssl rand -hex 8
#   COVE_LIVEKIT_API_SECRET: openssl rand -base64 36
COVE_LIVEKIT_API_KEY=
COVE_LIVEKIT_API_SECRET=

# Этот аккаунт при регистрации станет владельцем инстанса.
# (Первый зарегистрированный станет им в любом случае.)
COVE_ADMIN_USERNAME=mistychirp

# false => регистрация только по коду от владельца (модель Matrix).
COVE_OPEN_REGISTRATION=false

# Лимит на суммарный размер вложений одного сообщения.
COVE_MAX_UPLOAD_MB=25
