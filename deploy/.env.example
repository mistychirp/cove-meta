# Copy to .env and fill in. Never commit .env — it holds secrets.

# Instance domain. Caddy gets a Let's Encrypt certificate for it, so the
# A record must point at this server's public IP.
COVE_DOMAIN=mistyworks.servebeer.com

# Postgres password. Generate with: openssl rand -base64 24
COVE_DB_PASSWORD=

# LiveKit keys. The secret MUST be at least 32 characters.
#   COVE_LIVEKIT_API_KEY:    openssl rand -hex 8
#   COVE_LIVEKIT_API_SECRET: openssl rand -base64 36
COVE_LIVEKIT_API_KEY=
COVE_LIVEKIT_API_SECRET=

# This account becomes the instance owner when it registers.
# (The first account to register becomes the owner regardless.)
COVE_ADMIN_USERNAME=mistychirp

# false => registration only with a code from the owner (the Matrix model).
COVE_OPEN_REGISTRATION=false

# Cap on the total attachment size of a single message.
COVE_MAX_UPLOAD_MB=25
