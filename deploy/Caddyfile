# Caddy obtains and renews the Let's Encrypt certificate for COVE_DOMAIN itself.
# Client and API share one origin, so production needs no CORS at all.
{$COVE_DOMAIN} {
	encode zstd gzip

	# REST API
	handle /api/* {
		reverse_proxy server:8080
	}

	# WebSocket gateway. Caddy handles the upgrade on its own, no special config.
	handle /gateway {
		reverse_proxy server:8080
	}

	handle /health {
		reverse_proxy server:8080
	}

	# LiveKit signaling (WebSocket). Media does NOT go through here: it flows
	# straight to the host over UDP, bypassing Caddy. Hence the UDP port
	# forwards on the router matter.
	handle_path /livekit/* {
		reverse_proxy livekit:7880
	}

	# Everything else is the client bundle. SPA: unknown paths serve index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
